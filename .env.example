# ============================================================
# ΨΗΦΙΑΚΗ ΚΑΡΤΑ ΕΡΓΑΣΙΑΣ — SaaS Platform
# Περιβαλλοντικές Μεταβλητές
#
# ΟΔΗΓΙΕΣ:
#   1. cp .env.example .env
#   2. Συμπληρώστε τα πεδία με τις δικές σας τιμές
#   3. ΠΟΤΕ μην κάνετε commit το .env (είναι στο .gitignore)
# ============================================================

# --- Γενικά ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ergani_db
DB_USER=ergani_user
DB_PASSWORD=ergani_secure_pass_2026
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ergani-saas
KAFKA_GROUP_ID=ergani-workers

# --- ΕΡΓΑΝΗ ΙΙ API ---
# Sandbox (δοκιμαστικό — ΞΕΚΙΝΗΣΤΕ ΕΔΩ):
ERGANI_API_URL=https://trialeservices.yeka.gr/WebServicesAPI/api
# Production (πραγματικό — ΜΟΝΟ αφού ολοκληρωθεί testing):
# ERGANI_API_URL=https://eservices.yeka.gr/WebServicesAPI/api
ERGANI_ENV=sandbox
ERGANI_TIMEOUT_MS=30000
ERGANI_MAX_RETRIES=3

# --- Κρυπτογράφηση (AES-256-GCM) ---
# ΚΡΙΣΙΜΟ: Πρέπει να είναι 64 hex χαρακτήρες (= 32 bytes)
# Δημιουργία: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-hex-chars-encryption-key-here-change-this-immediately00
ENCRYPTION_IV_LENGTH=16

# --- Webhook Secrets ---
# Telegram (δωρεάν — ξεκινήστε εδώ)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
TELEGRAM_SECRET_TOKEN=your-random-secret-token

# Viber (payed — προαιρετικά)
VIBER_AUTH_TOKEN=your-viber-auth-token

# WhatsApp (δωρεάν μέχρι 1000/μήνα — προαιρετικά)
WHATSAPP_APP_SECRET=your-whatsapp-app-secret
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token

# --- GDPR ---
GPS_RETENTION_HOURS=48
AUDIT_LOG_RETENTION_YEARS=5

# --- Rate Limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# --- Ειδοποιήσεις Email (προαιρετικές) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
